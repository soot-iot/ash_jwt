[
  verbose: false,
  private: false,
  skip: false,
  router: "",
  exit: "Low",
  format: "txt",
  out: "",
  threshold: "low",
  # Traversal.FileModule flags AshJwt.Verifier.signer/2's File.read/1
  # of the operator-supplied PEM path. The path is supplied by the
  # operator at boot time (plug compile-time), not by the request, so
  # the traversal threat model does not apply.
  ignore: ["Traversal.FileModule"],
  ignore_files: [],
  details: nil,
  all_details: nil,
  mark_skip_all: nil,
  clear_skip: nil
]
